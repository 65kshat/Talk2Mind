    "## Augmentation of Audio Dataset\n",
    "\n",
    "def add_noise(signal, noise_factor=0.005):\n",
    "    noise = np.random.randn(len(signal))\n",
    "    augmented = (signal + noise_factor * noise)\n",
    "\n",
    "    return augmented.astype(np.float32)\n",
    "\n",
    "def volume_scale(signal):\n",
    "    factor = random.uniform(0.8, 1.2)\n",
    "\n",
    "    return signal * factor\n",
    "\n",
    "def pitch_shift(signal, sr):\n",
    "    steps = random.randint(-3, 3)\n",
    "\n",
    "    return librosa.effects.pitch_shift(signal, sr=sr, n_steps=steps)\n",
    "\n",
    "def time_stretch(signal):\n",
    "    rate = random.uniform(0.8, 1.2)\n",
    "\n",
    "    return librosa.effects.time_stretch(signal, rate=rate)"
   ]
  },
