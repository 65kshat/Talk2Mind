   ],
   "source": [
    "## Applying Feature Extraction\n",
    "\n",
    "emotion_to_idx = {\"Neutral\": 0, \"Calm\": 1, \"Happy\": 2, \"Sad\": 3, \"Angry\": 4, \"Fearful\": 5, \"Disgust\": 6, \"Surprised\": 7}\n",
    "TARGET_LENGTH = 150\n",
    "\n",
    "X = []\n",
    "y = []\n",
    "\n",
    "for _, row in df.iterrows():\n",
    "    signal, sr = librosa.load(row[\"Path\"], sr=22050)\n",
    "    augmented_signals = [signal, add_noise(signal), volume_scale(signal), pitch_shift(signal, sr), time_stretch(signal)]\n",
    "\n",
    "    for current_signal in augmented_signals:\n",
    "        mfcc = librosa.feature.mfcc(y=current_signal, sr=sr, n_mfcc=40)\n",
    "        rms = librosa.feature.rms(y=current_signal)\n",
    "        zcr = librosa.feature.zero_crossing_rate(current_signal)\n",
    "\n",
    "        mfcc = mfcc[:, :TARGET_LENGTH]\n",
    "        rms = rms[:, :TARGET_LENGTH]\n",
    "        zcr = zcr[:, :TARGET_LENGTH]\n",
    "\n",
    "        if mfcc.shape[1] < TARGET_LENGTH:\n",
    "            pad = (TARGET_LENGTH - mfcc.shape[1])\n",
    "            mfcc = np.pad(mfcc, ((0, 0), (0, pad)))\n",
    "            rms = np.pad(rms, ((0, 0), (0, pad)))\n",
    "            zcr = np.pad(zcr, ((0, 0), (0, pad)))\n",
    "\n",
    "        combined = np.vstack([mfcc, rms, zcr])\n",
    "        X.append(combined)\n",
    "        y.append(emotion_to_idx[row[\"Emotion\"]])\n",
    "\n",
    "X = np.array(X)\n",
    "y = np.array(y)\n",
    "print()\n",
    "\n",
    "print(\"Feature Shape:\", X.shape)\n",
    "print(\"Label Shape:\", y.shape)\n",
    "print(\"Total Samples:\", len(X))"
   ]
  },
